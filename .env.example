# Örnek ortam değişkenleri — `.env.local` kopyası oluşturup Vercel’e de aynı isimlerle ekleyin.

# Turso (production — https://turso.tech )
# Yerel geliştirmede boş bırakın; uygulama `data/deepfake-kiosk.db` dosyasını kullanır.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin API (sunucu)
ADMIN_PASSWORD=degistirin_guclu_sifre

# Admin giriş ekranı (istemciye gider; kiosk için pratik — üretimde mümkünse cookie tabanlı girişe geçin)
NEXT_PUBLIC_ADMIN_PASSWORD=degistirin_guclu_sifre
